// ~/.config/zellij/config.kdl
// Partial keybinds — Zellij merges these with its built-in defaults,
// so you only need what you want to change.

keybinds {
    // ---------------------------------------------------------------
    // (1) Stop Alt+Left / Alt+Right from jumping to the next tab
    //     when you're at the edge pane.
    //
    // Zellij's default binds Alt+h, Alt+l, Alt+Left, Alt+Right to
    // `MoveFocusOrTab`, which moves the pane focus and falls through
    // to a tab switch if there's no pane in that direction. We
    // override them with plain `MoveFocus` so they ONLY ever move
    // between panes — never tabs.
    //
    // (Alt+Up / Alt+Down already use MoveFocus by default, so they
    //  don't need changing.)
    // ---------------------------------------------------------------
    shared_except "locked" {
        bind "Alt h"     { MoveFocus "Left"; }
        bind "Alt l"     { MoveFocus "Right"; }
        bind "Alt Left"  { MoveFocus "Left"; }
        bind "Alt Right" { MoveFocus "Right"; }
    }

    // ---------------------------------------------------------------
    // (2) tmux-style prefix: Ctrl+a, then a digit jumps to that tab.
    //
    // Zellij has a built-in "Tmux" mode we can repurpose as the
    // prefix submenu. Ctrl+a enters it, a number jumps to the tab
    // and exits back to Normal mode. The bottom status bar will
    // show your bindings while you're in the mode.
    //
    // The list of `shared_except` modes excludes modes where Ctrl+a
    // would conflict with text entry (renaming, search, etc.).
    // ---------------------------------------------------------------
    shared_except "locked" "tmux" "renametab" "renamepane" "entersearch" {
        bind "Ctrl a" { SwitchToMode "Tmux"; }
    }

    tmux {
        // Numeric jumps. Zellij tabs are 1-indexed.
        bind "1" { GoToTab 1; SwitchToMode "Normal"; }
        bind "2" { GoToTab 2; SwitchToMode "Normal"; }
        bind "3" { GoToTab 3; SwitchToMode "Normal"; }
        bind "4" { GoToTab 4; SwitchToMode "Normal"; }
        bind "5" { GoToTab 5; SwitchToMode "Normal"; }
        bind "6" { GoToTab 6; SwitchToMode "Normal"; }
        bind "7" { GoToTab 7; SwitchToMode "Normal"; }
        bind "8" { GoToTab 8; SwitchToMode "Normal"; }
        bind "9" { GoToTab 9; SwitchToMode "Normal"; }

        // Optional tmux-flavored extras — delete any you don't want.
        bind "c" { NewTab; SwitchToMode "Normal"; }
        bind "n" { GoToNextTab; SwitchToMode "Normal"; }
        bind "p" { GoToPreviousTab; SwitchToMode "Normal"; }
        bind "d" { Detach; }
        bind "x" { CloseFocus; SwitchToMode "Normal"; }

        // Esc cancels back to Normal without doing anything.
        bind "Esc" { SwitchToMode "Normal"; }

        // Double-tap Ctrl+a to send a literal Ctrl+a to the program
        // inside the pane (tmux's prefix-prefix idiom). Byte 1 = ^A.
        bind "Ctrl a" { Write 1; SwitchToMode "Normal"; }
    }
}
